# Example environment variables
# Do NOT commit real API keys. Copy this file to .env and fill values.

# Google Gemini API key (preferred)
GEMINI_API_KEY=

# OpenAI API key (optional fallback for embeddings/LLM)
OPENAI_API_KEY=

# URL where the Python AI service is reachable from the backend (keep default if running on same host)
PYTHON_SERVICE_URL=http://127.0.0.1:8000

# MongoDB/Other backend secrets (if any)
# MONGO_URI=
# JWT_SECRET=
